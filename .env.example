# =============================================================================
# .env.example — Template PUBLIC de documentation des variables d'environnement
# =============================================================================
#
# Ce fichier documente les variables d'environnement utilisées dans le workspace.
# Il NE contient AUCUN secret réel : seulement des noms de variables et des
# valeurs d'exemple. Il peut être versionné et partagé sans risque.
#
# UTILISATION :
#   1. Copie ce fichier sous le nom ".env"   ->   cp .env.example .env
#   2. Remplace les valeurs d'exemple par tes vraies clés dans le ".env"
#   3. Le fichier ".env" est ignoré par git (voir .gitignore) : il ne sera
#      JAMAIS sauvegardé ni partagé.
#
# Ajoute ici toute nouvelle variable au fur et à mesure des projets.
# =============================================================================


# --- Agents vocaux IA --------------------------------------------------------
VAPI_API_KEY=ta_cle_vapi_ici
RETELL_API_KEY=ta_cle_retell_ici

# --- Automatisation ----------------------------------------------------------
MAKE_API_KEY=ta_cle_make_ici
N8N_API_KEY=ta_cle_n8n_ici
N8N_BASE_URL=https://ton-instance-n8n.exemple.com

# --- Modèles / IA ------------------------------------------------------------
ANTHROPIC_API_KEY=ta_cle_anthropic_ici
DEEPSEEK_API_KEY=ta_cle_deepseek_ici

# --- Hébergement / Cloud -----------------------------------------------------
CLOUD_SSH_HOST=adresse_de_ton_serveur
CLOUD_SSH_USER=ton_utilisateur
# Ne mets jamais de mot de passe ou de cle privee en clair ici.
# Reference plutot le chemin d'une cle SSH stockee hors du depot.
CLOUD_SSH_KEY_PATH=~/.ssh/ta_cle_privee

# --- Base de données (si applicable pour le SaaS) ----------------------------
DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/nom_de_la_base

# --- Email / Notifications (si applicable) -----------------------------------
SMTP_HOST=smtp.exemple.com
SMTP_USER=ton_email@exemple.com
SMTP_PASSWORD=ton_mot_de_passe_smtp
