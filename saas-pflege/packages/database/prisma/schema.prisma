// Prisma Schema – Len Len (SaaS ambulante Pflege)
// Multi-Tenant: jede fachliche Tabelle trägt organizationId.
// Tenant-Isolation wird zusätzlich per PostgreSQL Row-Level Security erzwungen
// (siehe prisma/rls.sql, als Migration eingespielt).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────────────────────────────────

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum InvoiceStatus {
  PAID
  OPEN
  FAILED
  VOID
}

enum UserRole {
  SUPER_ADMIN
  STRUKTUR_ADMIN
  KOORDINATOR
  HR
  FACHKRAFT
}

enum Locale {
  DE
  EN
  FR
}

enum GeocodingStatus {
  PENDING
  VALID
  INVALID
}

enum ContractType {
  FULL_100
  PART_80
  PART_50
  MINIJOB
  CUSTOM
}

enum Qualification {
  PFLEGEFACHKRAFT
  PFLEGEHILFSKRAFT
  BETREUUNGSKRAFT
  AUSZUBILDENDE
}

enum VisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
}

// ─────────────────────────────────────────────────────────────────────────
//  Tenant-Wurzel
// ─────────────────────────────────────────────────────────────────────────

model Organization {
  id                   String             @id @default(uuid()) @db.Uuid
  name                 String
  country              String             @default("DE")
  subscriptionPlan     SubscriptionPlan   @default(BASIC) @map("subscription_plan")
  subscriptionStatus   SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  planLimits           Json               @default("{}") @map("plan_limits")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  // Beginn der Karenzzeit (Regel 8): gesetzt beim ersten fehlgeschlagenen
  // Zahlungsversuch, geleert sobald wieder bezahlt wurde. Nach Ablauf von
  // BILLING_GRACE_PERIOD_DAYS suspendiert der Billing-Worker den Tenant.
  pastDueSince         DateTime?          @map("past_due_since")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  users      User[]
  caregivers Caregiver[]
  patients   Patient[]
  visits     Visit[]
  vehicles   Vehicle[]
  routes     Route[]
  auditLogs  AuditLog[]
  messages   Message[]
  gpsPositions GpsPosition[]
  invoices   Invoice[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────────────────
//  Identität & Zugriff
// ─────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  role           UserRole
  email          String
  passwordHash   String   @map("password_hash")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  mfaSecret      String?  @map("mfa_secret")
  language       Locale   @default(DE)
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caregiver     Caregiver?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  sentMessages  Message[]

  // E-Mail eindeutig pro Tenant
  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
//  Fachkräfte
// ─────────────────────────────────────────────────────────────────────────

model Caregiver {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String?       @unique @map("user_id") @db.Uuid
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  qualification  Qualification
  contractType   ContractType  @map("contract_type")
  weeklyHours    Decimal       @map("weekly_hours") @db.Decimal(5, 2)
  workDays       Json          @default("[]") @map("work_days") // z.B. ["MON","TUE","WED"]
  maxPatients    Int           @default(0) @map("max_patients")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedPatients  Patient[]    @relation("AssignedCaregiver")
  performedVisits   Visit[]      @relation("PerformingCaregiver")
  assignedVisits    Visit[]      @relation("AssignedVisitCaregiver")
  routes            Route[]
  messages          Message[]
  gpsPositions      GpsPosition[]

  @@index([organizationId])
  @@map("caregivers")
}

// ─────────────────────────────────────────────────────────────────────────
//  Chat (Fachkraft <-> Koordination)
// ─────────────────────────────────────────────────────────────────────────

// Eine Konversation pro Fachkraft (caregiverId = Konversationsschlüssel).
// Gegenseite ist das Planungsteam (Koordinator / Struktur-Admin).
model Message {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  caregiverId    String    @map("caregiver_id") @db.Uuid
  senderUserId   String    @map("sender_user_id") @db.Uuid
  body           String
  // Vom Empfänger-Lager gelesen (Fachkraft bzw. Koordination).
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caregiver    Caregiver    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, caregiverId, createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────────────────
//  Patienten
// ─────────────────────────────────────────────────────────────────────────

model Patient {
  id                  String          @id @default(uuid()) @db.Uuid
  organizationId      String          @map("organization_id") @db.Uuid
  assignedCaregiverId String?         @map("assigned_caregiver_id") @db.Uuid
  firstName           String          @map("first_name")
  lastName            String          @map("last_name")
  // Sensible Adressdaten werden AES-256-GCM verschlüsselt gespeichert
  rawAddress          String          @map("raw_address")
  normalizedAddress   String?         @map("normalized_address")
  latitude            Decimal?        @db.Decimal(9, 6)
  longitude           Decimal?        @db.Decimal(9, 6)
  geocodingScore      Decimal?        @map("geocoding_score") @db.Decimal(5, 4)
  geocodingStatus     GeocodingStatus @default(PENDING) @map("geocoding_status")
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedCaregiver Caregiver?   @relation("AssignedCaregiver", fields: [assignedCaregiverId], references: [id], onDelete: SetNull)
  visits            Visit[]

  @@index([organizationId])
  @@index([organizationId, geocodingStatus])
  @@map("patients")
}

// ─────────────────────────────────────────────────────────────────────────
//  Besuche
// ─────────────────────────────────────────────────────────────────────────

model Visit {
  id                  String      @id @default(uuid()) @db.Uuid
  organizationId      String      @map("organization_id") @db.Uuid
  patientId           String      @map("patient_id") @db.Uuid
  // caregiverId = effektiv durchgeführt (kann Vertretung sein)
  caregiverId         String?     @map("caregiver_id") @db.Uuid
  // assignedCaregiverId = attitré (Stamm-Fachkraft)
  assignedCaregiverId String?     @map("assigned_caregiver_id") @db.Uuid
  routeId             String?     @map("route_id") @db.Uuid
  scheduledAt         DateTime    @map("scheduled_at")
  status              VisitStatus @default(PLANNED)
  isEmergency         Boolean     @default(false) @map("is_emergency")
  emergencyReason     String?     @map("emergency_reason")
  gpsArrivalAt        DateTime?   @map("gps_arrival_at")
  gpsDepartureAt      DateTime?   @map("gps_departure_at")
  // Position beim Pointage (Mobile-App). Genauigkeit in Metern.
  gpsArrivalLat       Decimal?    @map("gps_arrival_lat") @db.Decimal(9, 6)
  gpsArrivalLng       Decimal?    @map("gps_arrival_lng") @db.Decimal(9, 6)
  gpsArrivalAccuracy  Float?      @map("gps_arrival_accuracy")
  gpsDepartureLat     Decimal?    @map("gps_departure_lat") @db.Decimal(9, 6)
  gpsDepartureLng     Decimal?    @map("gps_departure_lng") @db.Decimal(9, 6)
  gpsDepartureAccuracy Float?     @map("gps_departure_accuracy")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient           Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  caregiver         Caregiver?   @relation("PerformingCaregiver", fields: [caregiverId], references: [id], onDelete: SetNull)
  assignedCaregiver Caregiver?   @relation("AssignedVisitCaregiver", fields: [assignedCaregiverId], references: [id], onDelete: SetNull)
  route             Route?       @relation(fields: [routeId], references: [id], onDelete: SetNull)
  gpsPositions      GpsPosition[]

  @@index([organizationId])
  @@index([organizationId, scheduledAt])
  @@index([patientId, scheduledAt])
  @@index([organizationId, status])
  @@map("visits")
}

// ─────────────────────────────────────────────────────────────────────────
//  Fahrzeuge (Leasing)
// ─────────────────────────────────────────────────────────────────────────

model Vehicle {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  label          String
  leasingKmLimit Int       @map("leasing_km_limit")
  leasingKmUsed  Int       @default(0) @map("leasing_km_used")
  leasingEndDate DateTime? @map("leasing_end_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routes       Route[]

  @@index([organizationId])
  @@map("vehicles")
}

// ─────────────────────────────────────────────────────────────────────────
//  Touren (VRPTW-Ergebnis)
// ─────────────────────────────────────────────────────────────────────────

model Route {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  caregiverId    String?  @map("caregiver_id") @db.Uuid
  vehicleId      String?  @map("vehicle_id") @db.Uuid
  date           DateTime @db.Date
  visitsOrder    Json     @default("[]") @map("visits_order") // geordnete visitId-Liste
  optimized      Boolean  @default(false)
  vrptwScore     Decimal? @map("vrptw_score") @db.Decimal(5, 2)
  totalKm        Decimal? @map("total_km") @db.Decimal(8, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caregiver    Caregiver?   @relation(fields: [caregiverId], references: [id], onDelete: SetNull)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  visits       Visit[]

  @@index([organizationId])
  @@index([organizationId, date])
  @@map("routes")
}

// ─────────────────────────────────────────────────────────────────────────
//  Echtzeit-GPS-Tracking (Phase 2)
// ─────────────────────────────────────────────────────────────────────────

// Positionsverlauf der Fachkräfte während aktiver Besuche. DSGVO: jeder Punkt
// mit Zeitstempel, tenant-isoliert per RLS. distanceToPatientM/geofenceBreach
// werden beim Ingest berechnet (Geofencing 500 m um den geplanten Patienten).
model GpsPosition {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  caregiverId        String    @map("caregiver_id") @db.Uuid
  visitId            String?   @map("visit_id") @db.Uuid
  latitude           Decimal   @db.Decimal(9, 6)
  longitude          Decimal   @db.Decimal(9, 6)
  accuracy           Float?
  // Entfernung zum geplanten Patienten (m) + Geofence-Verletzung (>500 m).
  distanceToPatientM Float?    @map("distance_to_patient_m")
  geofenceBreach     Boolean   @default(false) @map("geofence_breach")
  // recordedAt = Zeitpunkt auf dem Gerät; createdAt = Eingang im Backend.
  recordedAt         DateTime  @map("recorded_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caregiver    Caregiver    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  visit        Visit?       @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, caregiverId, recordedAt(sort: Desc)])
  @@index([visitId])
  @@map("gps_positions")
}

// ─────────────────────────────────────────────────────────────────────────
//  Übersetzungen (i18n DB-Layer, ergänzt next-intl)
// ─────────────────────────────────────────────────────────────────────────

model Translation {
  id     String @id @default(uuid()) @db.Uuid
  locale Locale
  key    String
  value  String

  @@unique([locale, key])
  @@index([locale])
  @@map("translations")
}

// ─────────────────────────────────────────────────────────────────────────
//  Audit-Log (DSGVO: Lesen/Schreiben/Löschen von Patientendaten)
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String?     @map("user_id") @db.Uuid
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String?     @map("entity_id")
  metadata       Json        @default("{}")
  ipAddress      String?     @map("ip_address")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
//  Billing (Stripe)
// ─────────────────────────────────────────────────────────────────────────

// Rechnungs-Historie eines Tenants. Gespiegelt aus Stripe-Invoice-Events –
// Stripe bleibt die Quelle der Wahrheit, diese Tabelle dient der Anzeige unter
// /billing ohne Stripe-Roundtrip. Beträge in der kleinsten Währungseinheit
// (Cent), wie von Stripe geliefert.
model Invoice {
  id               String        @id @default(uuid()) @db.Uuid
  organizationId   String        @map("organization_id") @db.Uuid
  stripeInvoiceId  String        @unique @map("stripe_invoice_id")
  number           String?
  amountDue        Int           @map("amount_due")
  amountPaid       Int           @default(0) @map("amount_paid")
  currency         String        @default("eur")
  status           InvoiceStatus
  hostedInvoiceUrl String?       @map("hosted_invoice_url")
  invoicePdfUrl    String?       @map("invoice_pdf_url")
  issuedAt         DateTime      @map("issued_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, issuedAt])
  @@map("invoices")
}

// Verarbeitete Stripe-Events (Idempotenz). Stripe stellt Events MEHRFACH zu
// (at-least-once); die Event-ID als PK macht das Einfügen zum Gate: schlägt der
// Insert fehl, wurde das Event bereits verarbeitet und wird verworfen.
// System-Tabelle ohne organization_id -> keine RLS (nur System-Pfad schreibt).
model BillingWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("billing_webhook_events")
}
