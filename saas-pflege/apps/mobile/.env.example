# URL du backend vue DEPUIS LE TÉLÉPHONE.
# Sur un appareil physique (Expo Go), localhost = le téléphone lui-même :
# utiliser l'IP LAN du poste de dev, ex. http://192.168.1.20:4000
# (le backend écoute déjà sur 0.0.0.0). Émulateur Android : http://10.0.2.2:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
