# @types/react ne doit PAS être hoisté dans node_modules/.pnpm/node_modules :
# le web est en React 18, le mobile en React 19. Sans cette exclusion, les
# types de Next.js résolvent la version hoistée (19) et cassent le typecheck.
hoist-pattern[]=*
hoist-pattern[]=!@types/react
hoist-pattern[]=!@types/react-dom
